{
  "name": "@hermes/gateway-client",
  "version": "0.2.0",
  "description": "Shared client + server core for talking to the local Hermes OpenAI-compatible gateway.",
  "type": "module",
  "exports": {
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./attachments": {
      "types": "./dist/attachments.d.ts",
      "default": "./dist/attachments.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
